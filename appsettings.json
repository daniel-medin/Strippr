{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Strippr": {
    "FfmpegPath": "ffmpeg",
    "BundledFfmpegFolder": "tools/ffmpeg",
    "FfmpegDownloadUrl": "https://github.com/GyanD/codexffmpeg/releases/download/8.0.1/ffmpeg-8.0.1-essentials_build.zip",
    "StorageRoot": "App_Data",
    "UploadsFolder": "uploads",
    "OutputsFolder": "Strippr",
    "TempFolder": "temp",
    "MaxUploadMegabytes": 1024,
    "DefaultNoiseThreshold": "-30dB",
    "DefaultMinimumSilenceSeconds": 0.5,
    "DefaultCrossfadeMilliseconds": 80,
    "DefaultVideoCrossfadeFrames": 0,
    "DefaultPauseSpeedMultiplier": 1.0,
    "DefaultRetainedSilenceSeconds": 0.0,
    "MinimumKeepSegmentSeconds": 0.15
  }
}
