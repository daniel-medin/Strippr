@page
@model IndexModel
@{
    ViewData["Title"] = "Strip Silence From Local Video";
}

<section class="hero-shell">
    <div class="hero-copy">
        <p class="eyebrow">Editor workspace</p>
        <h1>Build the cut, then render.</h1>
        <p class="hero-text">
            Analyze the waveform, mark manual cuts, preview compressed pauses, and export the cleaned timeline without leaving your machine.
        </p>
        <div class="hero-strip">
            <span class="hero-chip">Waveform-first</span>
            <span class="hero-chip">Manual in/out cuts</span>
            <span class="hero-chip">Pause compression</span>
        </div>
    </div>
    <div class="health-panel @(Model.FfmpegAvailable ? "online" : "offline")">
        <span class="health-label">Render engine</span>
        <strong>@(Model.FfmpegAvailable ? "Ready" : "Missing")</strong>
        <p>@Model.FfmpegStatusMessage</p>
    </div>
</section>

<section class="panel-card process-card">
    <div class="panel-head">
        <div>
            <p class="panel-kicker">Timeline</p>
            <h2>Edit one clip</h2>
        </div>
    </div>

    <form
        method="post"
        enctype="multipart/form-data"
        class="strippr-form"
        data-processing-form
        data-default-noise-threshold="@Model.DefaultNoiseThresholdDbText"
        data-default-minimum-silence="@Model.DefaultMinimumSilenceSecondsText"
        data-default-retained-silence="@Model.DefaultRetainedSilenceSecondsText"
        data-default-cut-handles="@Model.DefaultCutHandleMillisecondsText"
        data-default-crossfade="@Model.DefaultCrossfadeMillisecondsText"
        data-default-video-crossfade="@Model.DefaultVideoCrossfadeFramesText"
        data-default-pause-speed="@Model.DefaultPauseSpeedMultiplierText">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <label class="dropzone" asp-for="Input.Video">
            <span class="dropzone-label">Video file</span>
            <input asp-for="Input.Video" type="file" accept="video/*" />
            <div class="dropzone-actions">
                <button class="secondary-button dropzone-button" type="button" data-pick-file>
                    Choose video...
                </button>
                <strong class="dropzone-file-name" data-file-name>No file selected</strong>
            </div>
            <span class="dropzone-copy">Choose a local video file to process.</span>
        </label>

        <div class="field-grid">
            <div class="field" data-setting-field="noise">
                <div class="field-topline">
                    <span>Noise threshold</span>
                    <div class="slider-head">
                        <label class="field-toggle">
                            <input asp-for="Input.EnableNoiseThreshold" class="field-toggle__input" data-setting-toggle="noise" />
                            <span class="field-toggle__label">On</span>
                        </label>
                        <strong class="dial-readout" data-noise-display>-30 dB</strong>
                    </div>
                </div>
                <input asp-for="Input.NoiseThreshold" type="hidden" />
                <input class="knob-input" type="range" min="-60" max="0" step="1" value="-30" data-noise-slider />
                <div class="slider-scale">
                    <span>-60 dB</span>
                    <span>0 dB</span>
                </div>
                <small class="field-help">Sets how quiet audio must be before Strippr treats it as silence. If this or Minimum silence is off, automatic silence detection is fully bypassed.</small>
            </div>

            <div class="field" data-setting-field="silence">
                <div class="field-topline">
                    <span>Minimum silence</span>
                    <div class="slider-head">
                        <label class="field-toggle">
                            <input asp-for="Input.EnableMinimumSilence" class="field-toggle__input" data-setting-toggle="silence" />
                            <span class="field-toggle__label">On</span>
                        </label>
                        <strong class="dial-readout" data-silence-display>0.5 s</strong>
                    </div>
                </div>
                <input class="knob-input" asp-for="Input.MinimumSilenceSeconds" type="range" min="0.1" max="3" step="0.1" data-silence-slider />
                <div class="slider-scale">
                    <span>0.1 s</span>
                    <span>3.0 s</span>
                </div>
                <small class="field-help">Silent audio must last at least this long before Strippr edits it. If this or Noise threshold is off, automatic silence detection is fully bypassed.</small>
            </div>

            <div class="field" data-setting-field="retained-silence">
                <div class="field-topline">
                    <span>Min kept pause</span>
                    <div class="slider-head">
                        <label class="field-toggle">
                            <input asp-for="Input.EnableRetainedSilence" class="field-toggle__input" data-setting-toggle="retained-silence" />
                            <span class="field-toggle__label">On</span>
                        </label>
                        <strong class="dial-readout" data-retained-silence-display>0.00 s</strong>
                    </div>
                </div>
                <input class="knob-input" asp-for="Input.RetainedSilenceSeconds" type="range" min="0" max="1" step="0.05" data-retained-silence-slider />
                <div class="slider-scale">
                    <span>0.00 s</span>
                    <span>1.00 s</span>
                </div>
                <small class="field-help">Leaves at least this much pause in the finished result after an automatic silence edit.</small>
            </div>

            <div class="field" data-setting-field="cut-handles">
                <div class="field-topline">
                    <span>Cut handles</span>
                    <div class="slider-head">
                        <label class="field-toggle">
                            <input asp-for="Input.EnableCutHandles" class="field-toggle__input" data-setting-toggle="cut-handles" />
                            <span class="field-toggle__label">On</span>
                        </label>
                        <strong class="dial-readout" data-cut-handle-display>120 ms</strong>
                    </div>
                </div>
                <input class="knob-input" asp-for="Input.CutHandleMilliseconds" type="range" min="0" max="500" step="10" data-cut-handle-slider />
                <div class="slider-scale">
                    <span>0 ms</span>
                    <span>500 ms</span>
                </div>
                <small class="field-help">Keeps this much untouched silence on both sides of automatic silence edits to soften jumps.</small>
            </div>

            <div class="field" data-setting-field="crossfade">
                <div class="field-topline">
                    <span>Crossfade</span>
                    <div class="slider-head">
                        <label class="field-toggle">
                            <input asp-for="Input.EnableCrossfade" class="field-toggle__input" data-setting-toggle="crossfade" />
                            <span class="field-toggle__label">On</span>
                        </label>
                        <strong class="dial-readout" data-crossfade-display>80 ms</strong>
                    </div>
                </div>
                <input class="knob-input" asp-for="Input.CrossfadeMilliseconds" type="range" min="0" max="500" step="5" data-crossfade-slider />
                <div class="slider-scale">
                    <span>0 ms</span>
                    <span>500 ms</span>
                </div>
                <small class="field-help">Crossfades audio at hard cut points to reduce clicks and abrupt joins.</small>
            </div>

            <div class="field" data-setting-field="video-crossfade">
                <div class="field-topline">
                    <span>Video crossfade</span>
                    <div class="slider-head">
                        <label class="field-toggle">
                            <input asp-for="Input.EnableVideoCrossfade" class="field-toggle__input" data-setting-toggle="video-crossfade" />
                            <span class="field-toggle__label">On</span>
                        </label>
                        <strong class="dial-readout" data-video-crossfade-display>0 fr</strong>
                    </div>
                </div>
                <input class="knob-input" asp-for="Input.VideoCrossfadeFrames" type="range" min="0" max="48" step="1" data-video-crossfade-slider />
                <div class="slider-scale">
                    <span>0 fr</span>
                    <span>48 fr</span>
                </div>
                <small class="field-help">Blends adjacent video shots over a short frame range on hard cuts.</small>
            </div>

            <div class="field field--wide" data-setting-field="pause-speed">
                <div class="field-topline">
                    <span>Pause speed</span>
                    <div class="slider-head">
                        <label class="field-toggle">
                            <input asp-for="Input.EnablePauseSpeed" class="field-toggle__input" data-setting-toggle="pause-speed" />
                            <span class="field-toggle__label">On</span>
                        </label>
                        <strong class="dial-readout" data-pause-speed-display>1.0x</strong>
                    </div>
                </div>
                <input class="knob-input" asp-for="Input.PauseSpeedMultiplier" type="range" min="1" max="10" step="0.1" data-pause-speed-slider />
                <div class="slider-scale">
                    <span>1.0x</span>
                    <span>Cut -> compress</span>
                    <span>10.0x</span>
                </div>
                <small class="field-help"><code>1.0x</code> uses the minimum kept pause. Higher values compress silence faster instead of fully removing it.</small>
            </div>
        </div>

        <input asp-for="Input.ManualCutRangesJson" type="hidden" data-manual-cut-ranges />
        <input asp-for="Input.AiCutRangesJson" type="hidden" data-ai-cut-ranges />
        <input asp-for="Input.AiContentCutRangesJson" type="hidden" data-ai-content-cut-ranges />

        <section class="waveform-panel" data-waveform-panel hidden>
            <div class="waveform-head">
                <div>
                    <p class="panel-kicker">Timeline monitor</p>
                    <h3>Waveform editor</h3>
                </div>
                <span class="waveform-threshold" data-threshold-readout>-30dB</span>
            </div>
            <div class="waveform-toolbar">
                <label class="waveform-control waveform-control--zoom">
                    <span>Vertical zoom</span>
                    <div class="ruler-slider" style="--min: 1; --val: 1; --max: 6">
                        <input id="waveform-vertical-zoom" class="ruler-slider__input" type="range" min="1" max="6" step="0.1" value="1" list="waveform-vertical-zoom-scale" data-waveform-vertical-zoom />
                        <output class="ruler-slider__output" for="waveform-vertical-zoom" data-waveform-vertical-display>1.0x</output>
                        <datalist id="waveform-vertical-zoom-scale" class="ruler-slider__scale">
                            @for (var tick = 1; tick <= 6; tick++)
                            {
                                <option value="@tick" label="@tick" style="--idx:@tick"></option>
                            }
                        </datalist>
                    </div>
                </label>
                <label class="waveform-control waveform-control--zoom">
                    <span>Horizontal zoom</span>
                    <div class="ruler-slider" style="--min: 1; --val: 1; --max: 12">
                        <input id="waveform-horizontal-zoom" class="ruler-slider__input" type="range" min="1" max="12" step="0.5" value="1" list="waveform-horizontal-zoom-scale" data-waveform-horizontal-zoom />
                        <output class="ruler-slider__output" for="waveform-horizontal-zoom" data-waveform-horizontal-display>1.0x</output>
                        <datalist id="waveform-horizontal-zoom-scale" class="ruler-slider__scale">
                            @for (var tick = 1; tick <= 12; tick++)
                            {
                                <option value="@tick" label="@(tick == 12 || tick == 1 || tick % 2 == 0 ? tick : null)" style="--idx:@tick"></option>
                            }
                        </datalist>
                    </div>
                </label>
            </div>
            <section
                class="ai-analysis-panel"
                data-ai-default-key-available="@Model.HasConfiguredOpenAiApiKey.ToString().ToLowerInvariant()"
                data-ai-default-model="@Model.DefaultOpenAiModel">
                <div class="ai-analysis-head">
                    <div>
                        <p class="panel-kicker">AI overlay</p>
                        <strong>Transcript gap detection</strong>
                    </div>
                    <div class="ai-analysis-headline">
                        <span class="ai-analysis-tag">@(Model.HasConfiguredOpenAiApiKey ? "Local key ready" : "Overlay only")</span>
                        <label class="field-toggle ai-analysis-toggle">
                            <input class="field-toggle__input" type="checkbox" data-ai-enabled />
                            <span class="field-toggle__label">On</span>
                        </label>
                    </div>
                </div>
                <div class="ai-analysis-grid">
                    <label class="ai-analysis-field">
                        <span>OpenAI API key</span>
                        <input
                            type="password"
                            autocomplete="off"
                            spellcheck="false"
                            placeholder="@(Model.HasConfiguredOpenAiApiKey ? "Leave blank to use local key" : "sk-...")"
                            data-ai-api-key />
                    </label>
                    <label class="ai-analysis-field">
                        <span>Model</span>
                        <select data-ai-model>
                            <option value="whisper-1">whisper-1</option>
                        </select>
                    </label>
                    <label class="ai-analysis-field">
                        <span>Spoken language</span>
                        <select data-ai-language>
                            <option value="en">English</option>
                            <option value="">Auto detect</option>
                            <option value="sv">Swedish</option>
                        </select>
                    </label>
                    <div class="ai-analysis-actions">
                        <button class="secondary-button" type="button" data-ai-analyze>
                            <span class="ai-analysis-spinner" hidden aria-hidden="true"></span>
                            <span data-ai-analyze-label>Analyze with AI</span>
                        </button>
                        <button class="secondary-button" type="button" data-ai-clear hidden>Clear AI overlay</button>
                    </div>
                </div>
                <p class="ai-analysis-help">
                    @if (Model.HasConfiguredOpenAiApiKey)
                    {
                        <text>Uses OpenAI transcript timing gaps, then trims them against the local waveform so non-silent audio does not get marked as silence. A local key is configured on this machine, so you can leave the field blank or override it for one run. Set Spoken language if auto-detect drifts. This overlay currently uses timestamp-capable transcription models only. AI ranges do not change manual cuts.</text>
                    }
                    else
                    {
                        <text>Uses OpenAI transcript timing gaps, then trims them against the local waveform so non-silent audio does not get marked as silence. The API key stays in this local app flow, Strippr does not save it, and this overlay currently uses timestamp-capable transcription models only. Set Spoken language if auto-detect drifts. AI ranges do not change manual cuts.</text>
                    }
                </p>
                <p class="ai-analysis-status" data-ai-status hidden></p>
            </section>
            <section
                class="ai-content-panel"
                data-ai-content-default-key-available="@Model.HasConfiguredOpenAiApiKey.ToString().ToLowerInvariant()">
                <div class="ai-content-head">
                    <div>
                        <p class="panel-kicker">A2</p>
                        <strong>Content-aware retake detector</strong>
                    </div>
                    <label class="field-toggle ai-content-toggle">
                        <input class="field-toggle__input" type="checkbox" data-ai-content-enabled />
                        <span class="field-toggle__label">Off</span>
                    </label>
                </div>
                <div class="ai-content-grid">
                    <label class="ai-content-field">
                        <span>Analysis model</span>
                        <select data-ai-content-model>
                            <option value="gpt-5.2">gpt-5.2</option>
                            <option value="gpt-5">gpt-5</option>
                            <option value="gpt-5-mini">gpt-5-mini</option>
                            <option value="gpt-4o-mini">gpt-4o-mini</option>
                        </select>
                    </label>
                    <div class="ai-content-actions">
                        <button class="secondary-button" type="button" data-ai-content-analyze>
                            <span class="ai-analysis-spinner" hidden aria-hidden="true" data-ai-content-spinner></span>
                            <span data-ai-content-analyze-label>Analyze content</span>
                        </button>
                        <button class="secondary-button" type="button" data-ai-content-clear hidden>Clear A2</button>
                    </div>
                </div>
                <p class="ai-content-help">
                    Uses Whisper for timestamped transcript recovery, then runs a second reasoning pass to look for false starts, self-corrections, repeated phrases, filler-heavy stumbles, and likely spoken mistakes. A2 reuses the OpenAI key and spoken-language setting above and shows both suggested cut ranges and transcript text.
                </p>
                <p class="ai-content-status" data-ai-content-status hidden></p>
                <div class="ai-content-results" data-ai-content-results hidden>
                    <div class="ai-content-issues" data-ai-content-issues></div>
                    <div class="ai-content-transcript">
                        <div class="ai-content-transcript-head">
                            <span>Transcript</span>
                            <span class="ai-content-transcript-tag" data-ai-content-transcript-model hidden></span>
                        </div>
                        <div class="ai-content-transcript-body" data-ai-content-transcript-body></div>
                    </div>
                </div>
            </section>
            <div class="waveform-actions">
                <div class="waveform-action-buttons">
                    <button class="timeline-button" type="button" data-waveform-play disabled>Play audio (Space)</button>
                    <button class="timeline-button" type="button" data-waveform-play-result disabled>Play result (R)</button>
                    <button class="timeline-button" type="button" data-add-marker="in">Add in (A)</button>
                    <button class="timeline-button" type="button" data-add-marker="out">Add out (S)</button>
                </div>
                <p class="waveform-help">
                    Blue regions show automatic silence edits. Orange regions show manual cuts. Click the waveform to place the playhead, then play audio, preview the result, or add In and Out markers.
                </p>
            </div>
            <div class="waveform-viewport" data-waveform-viewport>
                <div class="waveform-stage" data-waveform-stage>
                    <canvas class="waveform-canvas" data-waveform-canvas></canvas>
                    <div class="waveform-ai-overlay" data-ai-waveform-overlay></div>
                    <div class="waveform-ai-content-overlay" data-ai-content-waveform-overlay></div>
                    <div class="waveform-overlay" data-waveform-overlay></div>
                </div>
            </div>
            <div class="waveform-scale">
                <span>0 dB</span>
                <span>Scroll horizontally when zoomed in</span>
                <span>-inf</span>
            </div>
            <p class="waveform-status" data-waveform-status>Choose a video file to analyze its audio.</p>
            <p class="marker-summary" data-marker-summary hidden></p>
            <div class="marker-list" data-marker-list hidden></div>
        </section>

        <div class="form-actions">
            <button class="submit-button" type="submit" disabled="@(!Model.FfmpegAvailable)">
                Process video
            </button>
            <button class="secondary-button" type="button" data-disable-all>
                Turn off all
            </button>
            <button class="secondary-button" type="button" data-reset-all>
                Reset all
            </button>
        </div>

        <div class="processing-panel" data-processing-panel hidden aria-live="polite">
            <div class="processing-head">
                <strong data-processing-label>Preparing upload...</strong>
                <span data-processing-percent>0%</span>
            </div>
            <div class="processing-bar" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" data-processing-bar>
                <span class="processing-bar-fill" data-processing-fill></span>
            </div>
            <p class="processing-copy">Large videos can take a while. Keep this tab open until the result reloads.</p>
        </div>
    </form>
</section>

<section class="panel-card result-card-full" data-result-panel>
    <div class="panel-head">
        <div>
            <p class="panel-kicker">Render output</p>
            <h2>Latest export</h2>
        </div>
    </div>

    @if (Model.Result is null)
    {
        <p class="empty-state">Run a file through the form to get a downloadable output here.</p>
    }
    else
    {
        <div class="result-summary @(Model.Result.Success ? "success" : "failure")">
            <strong>@Model.Result.Message</strong>
            <span>@Model.Result.OriginalFileName</span>
        </div>

        @if (Model.Result.Success)
        {
            <dl class="stats-grid">
                <div>
                    <dt>Source length</dt>
                    <dd>@Model.FormatSeconds(Model.Result.SourceDurationSeconds)</dd>
                </div>
                <div>
                    <dt>Output length</dt>
                    <dd>@Model.FormatSeconds(Model.Result.OutputDurationSeconds)</dd>
                </div>
                <div>
                    <dt>Removed</dt>
                    <dd>@Model.FormatSeconds(Model.Result.RemovedDurationSeconds)</dd>
                </div>
                <div>
                    <dt>Edited ranges</dt>
                    <dd>@Model.Result.RemovedSegmentsCount</dd>
                </div>
            </dl>

            <div class="download-actions">
                <button
                    class="download-link save-as-button"
                    type="button"
                    data-save-file
                    data-download-url="@Model.Result.OutputUrl"
                    data-file-name="@Model.Result.OutputFileName">
                    Save As...
                </button>

                <a class="download-link secondary-link" href="@Model.Result.OutputUrl" download="@Model.Result.OutputFileName">
                    Download cleaned video
                </a>
            </div>

            <p class="save-status" data-save-status hidden></p>

            <p class="saved-path">
                Export complete. Use <strong>Save As...</strong> to choose where the finished file goes.
            </p>
        }
    }
</section>

<template data-empty-result-panel-template>
    <section class="panel-card result-card-full" data-result-panel>
        <div class="panel-head">
            <div>
                <p class="panel-kicker">Render output</p>
                <h2>Latest export</h2>
            </div>
        </div>

        <p class="empty-state">Run a file through the form to get a downloadable output here.</p>
    </section>
</template>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
